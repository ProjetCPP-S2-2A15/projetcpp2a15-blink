    <property name="styleSheet">
     <string notr="true">/* 🌟 QListWidget (Main List) */
QListWidget {
    background-color: white;  /* White background */
    border: 2px solid #ccc;  /* Light grey border */
    border-radius: 8px;
    color: black;  /* Black text */
    font-size: 14px;
    padding: 5px;
}

/* List Items */
QListWidget::item {
    background-color: #f8f9fa;  /* Light grey background */
    padding: 10px;
    margin: 4px;
    border-radius: 5px;
    transition: all 0.3s ease-in-out; /* Smooth animation */
}

/* Hover Effect (Animated) */
QListWidget::item:hover {
    background-color: #dce7ff;  /* Light blue when hovered */
    color: black;
    transform: scale(1.05); /* Slightly enlarge on hover */
}

/* Selected Item (Animated) */
QListWidget::item:selected {
    background-color: #4a90e2;  /* Blue selection */
    color: white;
    font-weight: bold;
    transform: scale(1.1); /* Make it pop */
}

/* Scrollbar (Optional) */
QScrollBar:vertical {
    border: none;
    background: #f1f1f1;
    width: 10px;
    margin: 0px 0px 0px 0px;
}

QScrollBar::handle:vertical {
    background: #c1c1c1;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #4a90e2;
}

</string>
